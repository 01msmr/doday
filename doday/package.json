{
  "name": "doday",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src server",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"server/**/*.ts\" \"*.{json,html,md}\""
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
