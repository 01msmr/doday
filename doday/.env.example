# Vorlage: nach .env kopieren und ausfüllen (`cp .env.example .env`).
# Die .env ist per .gitignore ausgeschlossen – Zugangsdaten landen nie im Repo.

# Deine Nextcloud-Instanz
NEXTCLOUD_URL=https://cd.msmr.co
NEXTCLOUD_USER=uli

# App-Passwort aus Nextcloud (Einstellungen → Sicherheit → Geräte & Sitzungen
# → "App-Name" eingeben → "Neues App-Passwort erstellen")
NEXTCLOUD_APP_PASSWORD=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx

# Ordner für die App-Daten in deinen Nextcloud-Dateien (wird automatisch angelegt)
DODAY_DATA_DIR=/Notes/DoDay

# Port des Backends (Vite-Dev-Proxy und Traefik erwarten 3000)
PORT=3000
