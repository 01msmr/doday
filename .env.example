# Vorlage: nach .env kopieren und ausfüllen (`cp .env.example .env`).
# Die .env ist per .gitignore ausgeschlossen – Zugangsdaten landen nie im Repo.

# Deine Nextcloud-Instanz
NEXTCLOUD_URL=https://cd.msmr.co
NEXTCLOUD_USER=uli

# App-Passwort aus Nextcloud (Einstellungen → Sicherheit → Geräte & Sitzungen
# → "App-Name" eingeben → "Neues App-Passwort erstellen")
NEXTCLOUD_APP_PASSWORD=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx

# Ordner für die App-Daten in deinen Nextcloud-Dateien (wird automatisch angelegt)
DODAY_DATA_DIR=/Notes/DoDay

# Port des Backends (Vite-Dev-Proxy und Traefik erwarten 3000)
PORT=3000

# Cookie-Login (ersetzt Basic Auth): Sobald DODAY_PASSWORD gesetzt ist, schützt das
# Backend App + API mit einem Login. Nach einmaliger Anmeldung hält ein signiertes
# Cookie 90 Tage – iOS fragt beim PWA-Start nicht mehr ständig nach.
# Leer lassen (z. B. lokaler Dev) = kein Schutz.
# DODAY_PASSWORD=ein-langes-passwort
# Optional: stabiler HMAC-Schlüssel fürs Cookie. Ohne Angabe aus dem Passwort
# abgeleitet (Passwortwechsel meldet dann alle Sitzungen ab).
# DODAY_AUTH_SECRET=zufaelliger-langer-string

# Optional: Ziel-Kalender fürs Anlegen (Anzeigename in Nextcloud).
# Ohne Angabe nimmt doday den ersten passenden Kalender.
# DODAY_EVENTS_CALENDAR=Persönlich
# DODAY_TASKS_CALENDAR=Aufgaben
